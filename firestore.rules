rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserData() {
      return currentUserDoc().data;
    }

    function currentUserRole() {
      return currentUserExists() && ('role' in currentUserData())
        ? currentUserData().role
        : 'studio';
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isStudio() {
      return signedIn() && currentUserRole() == 'studio';
    }

    function isClient() {
      return signedIn() && currentUserRole() == 'client';
    }

    function studioOwnsIncomingRecord() {
      return isStudio() && request.resource.data.user_id == request.auth.uid;
    }

    function studioOwnsExistingRecord() {
      return isStudio() && resource.data.user_id == request.auth.uid;
    }

    function studioKeepsOwnership() {
      return request.resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == resource.data.user_id;
    }

    function clientCanReadRecord() {
      return isClient()
        && resource.data.client_id == currentUserData().client_id
        && resource.data.user_id == currentUserData().studio_owner_id;
    }

    function clientCanReadOwnClient(clientId) {
      return isClient()
        && clientId == currentUserData().client_id
        && resource.data.user_id == currentUserData().studio_owner_id;
    }

    function clientCanCreateMessage() {
      return isClient()
        && request.resource.data.client_id == currentUserData().client_id
        && request.resource.data.user_id == currentUserData().studio_owner_id
        && request.resource.data.sender_role == 'client'
        && request.resource.data.outbound == false;
    }

    function publicFormTargetExists() {
      return request.resource.data.user_id is string
        && request.resource.data.user_id.size() > 0
        && exists(/databases/$(database)/documents/users/$(request.resource.data.user_id));
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create, update, delete: if isOwner(userId);
    }

    match /clients/{docId} {
      allow create: if studioOwnsIncomingRecord();
      allow get, list: if studioOwnsExistingRecord() || clientCanReadOwnClient(docId);
      allow update, delete: if studioOwnsExistingRecord() && studioKeepsOwnership();
    }

    match /projects/{docId} {
      allow create: if studioOwnsIncomingRecord();
      allow get, list: if studioOwnsExistingRecord() || clientCanReadRecord();
      allow update, delete: if studioOwnsExistingRecord() && studioKeepsOwnership();
    }

    match /invoices/{docId} {
      allow create: if studioOwnsIncomingRecord();
      allow get, list: if studioOwnsExistingRecord() || clientCanReadRecord();
      allow update, delete: if studioOwnsExistingRecord() && studioKeepsOwnership();
    }

    match /proposals/{docId} {
      allow create: if studioOwnsIncomingRecord();
      allow get, list: if studioOwnsExistingRecord() || clientCanReadRecord();
      allow update, delete: if studioOwnsExistingRecord() && studioKeepsOwnership();
    }

    match /contracts/{docId} {
      allow create: if studioOwnsIncomingRecord();
      allow get, list: if studioOwnsExistingRecord() || clientCanReadRecord();
      allow update, delete: if studioOwnsExistingRecord() && studioKeepsOwnership();
    }

    match /events/{docId} {
      allow create: if studioOwnsIncomingRecord();
      allow get, list: if studioOwnsExistingRecord() || clientCanReadRecord();
      allow update, delete: if studioOwnsExistingRecord() && studioKeepsOwnership();
    }

    match /messages/{docId} {
      allow create: if studioOwnsIncomingRecord() || clientCanCreateMessage();
      allow get, list: if studioOwnsExistingRecord() || clientCanReadRecord();
      allow update, delete: if studioOwnsExistingRecord() && studioKeepsOwnership();
    }

    match /form_configs/{userId} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if isStudio() && request.auth.uid == userId && request.resource.data.user_id == request.auth.uid;
    }

    match /form_submissions/{docId} {
      allow create: if publicFormTargetExists()
        && request.resource.data.data is map
        && request.resource.data.submitted_at is string
        && request.resource.data.keys().hasOnly(['user_id', 'data', 'submitted_at']);
      allow get, list: if studioOwnsExistingRecord();
      allow update, delete: if false;
    }
  }
}
